{
  "version": 10,
  "configurePresets": [
    {
      "name": "base",
      "generator": "Ninja",
      "cacheVariables": {
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "CMAKE_BUILD_TYPE": "Release"
      }
    },
    {
      "name": "dev",
      "inherits": ["base"],
      "binaryDir": "${sourceDir}/build/dev",
      "cacheVariables": {
        "GAME_HOT_RELOAD": "ON",
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "release",
      "inherits": ["base"],
      "binaryDir": "${sourceDir}/build/release",
      "cacheVariables": {
        "GAME_HOT_RELOAD": "OFF"
      }
    },
    {
      "name": "clang-dev",
      "inherits": ["clang", "dev"]
    },
    {
      "name": "clang-release",
      "inherits": ["clang", "release"]
    },
    {
      "name": "gcc-dev",
      "inherits": ["gcc", "dev"]
    },
    {
      "name": "gcc-release",
      "inherits": ["gcc", "release"]
    },
    {
      "name": "clang-cl-dev",
      "inherits": ["clang-cl", "dev"]
    },
    {
      "name": "clang-cl-release",
      "inherits": ["clang-cl", "release"]
    },
    {
      "name": "x86_64-w64-mingw32-release",
      "inherits": ["x86_64-w64-mingw32", "release"]
    },
    {
      "name": "web-release",
      "inherits": ["release"],
      "binaryDir": "${sourceDir}/build/web",
      "cacheVariables": {
        "CMAKE_TOOLCHAIN_FILE": "$env{EMSDK}/upstream/emscripten/cmake/Modules/Platform/Emscripten.cmake",
        "CMAKE_BUILD_TYPE": "MinSizeRel"
      }
    },
    {
      "name": "clang",
      "hidden": true,
      "cacheVariables": {
        "CMAKE_C_COMPILER": "clang",
        "CMAKE_CXX_COMPILER": "clang++",
	"CMAKE_LINKER": "clang"
      }
    },
    {
      "name": "gcc",
      "hidden": true,
      "inherits": ["base"],
      "cacheVariables": {
        "CMAKE_C_COMPILER": "gcc",
        "CMAKE_CXX_COMPILER": "g++"
      }
    },
    {
      "name": "clang-cl",
      "hidden": true,
      "inherits": ["base"],
      "cacheVariables": {
        "CMAKE_C_COMPILER": "clang-cl",
        "CMAKE_CXX_COMPILER": "clang-cl"
      }
    },
    {
      "name": "x86_64-w64-mingw32",
      "hidden": true,
      "inherits": ["base"],
      "cacheVariables": {
        "CMAKE_SYSTEM_NAME": "Windows",
        "CMAKE_SYSTEM_PROCESSOR": "x86_64",
        "CMAKE_C_COMPILER": "x86_64-w64-mingw32-gcc",
        "CMAKE_CXX_COMPILER": "x86_64-w64-mingw32-g++",
        "CMAKE_RC_COMPILER": "x86_64-w64-mingw32-windres"
      }
    }
  ]
}
